# ─────────────────────────────────────────────────────────────────────────
# Wondersun · environment variables
# Copia in .env.local e compila i valori
# ─────────────────────────────────────────────────────────────────────────

# ── Supabase ─────────────────────────────────────────────────────────────
# Vai su https://app.supabase.com → progetto → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...           # solo lato server, mai esposta al client
SUPABASE_PROJECT_ID=xxxx                        # per generare i tipi via supabase CLI

# ── Pagamenti ────────────────────────────────────────────────────────────
# Provider ancora in valutazione (Stripe vs PayPal). Gli endpoint di pagamento
# (quota prenotazione e canone fornitore) restano "pending" finché non si
# configura almeno uno dei due.
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Stripe Price ID per abbonamento mensile fornitore (€29/mese · 3 mesi trial)
STRIPE_SUPPLIER_SUBSCRIPTION_PRICE_ID=price_...
# In alternativa PayPal
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# Corrispettivo digitale Wondersun (modello concierge):
# il cliente paga ONLINE il 15% del prezzo, IN AGGIUNTA; il fornitore incassa il prezzo pieno.
WONDERSUN_COMMISSION_PCT=15                      # % del prezzo esperienza, a carico del cliente
# NOTE: le ex-variabili WONDERSUN_HIGH_VALUE_THRESHOLD e _FIXED_FEE sono state
# rimosse: la committente ha deciso che le esperienze sopra €1.000 diventano
# "vetrina" con canone mensile separato e niente prenotazione diretta.

# ── Mapbox (Sprint 2 · mappa interattiva) ────────────────────────────────
NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ1...

# ── Anthropic Claude (Sprint 5 · chatbot Sole) ───────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Email transazionali ──────────────────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM=Wondersun <noreply@wondersun.it>

# ── WhatsApp Cloud API (notifiche prenotazioni ai fornitori) ──────────────
# I fornitori guardano più WhatsApp che email: notifica la prenotazione in entrata.
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=

# ── App ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SUPPORT_WHATSAPP=+39XXXXXXXXXX     # per escalation chatbot Sole

# ── Demo (presentazione alla committente) ────────────────────────────────
# Se "true" abilita la pagina /demo con account preconfigurati (cliente,
# fornitore approvato, admin) e relativo auto-login. Lasciare vuoto o
# impostare a "false" in produzione.
NEXT_PUBLIC_DEMO_MODE=false

# ── Monitoring (opzionale, Allegato A § 1.1) ────────────────────────────
# Senza DSN: il modulo lib/sentry.ts è no-op (logga in console).
# Per attivare: npm i @sentry/nextjs, poi impostare DSN qui sotto.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
